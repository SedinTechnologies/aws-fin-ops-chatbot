aws-iac: uvicorn --factory awslabs.aws_iac_mcp_server.server:mcp.http_app --host 0.0.0.0 --port 8001

cloudwatch: uvicorn --factory awslabs.cloudwatch_mcp_server.server:mcp.streamable_http_app --host 0.0.0.0 --port 8002

billing: uvicorn --factory billing_server:create_app --host 0.0.0.0 --port 8003

cloudtrail: uvicorn --factory awslabs.cloudtrail_mcp_server.server:mcp.streamable_http_app --host 0.0.0.0 --port 8004

pricing: uvicorn --factory awslabs.aws_pricing_mcp_server.server:mcp.streamable_http_app --host 0.0.0.0 --port 8005
