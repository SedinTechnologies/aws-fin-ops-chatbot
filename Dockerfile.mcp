FROM python:3.13.12-slim

WORKDIR /app

COPY requirements.mcp.txt ./

RUN apt-get update \
  && apt-get install -y --no-install-recommends \
     build-essential curl \
  && curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y \
  && . "$HOME/.cargo/env" \
  && pip install --no-cache-dir -r requirements.mcp.txt \
  && apt-get purge -y --auto-remove build-essential curl \
  && rm -rf /var/lib/apt/lists/* /root/.cargo /root/.rustup

COPY Procfile.mcp ./Procfile

COPY scripts/aws_billing_server.py /app/aws_billing_server.py

EXPOSE 8000 8001 8002 8003 8004 8005

ENV AUTH_TYPE="no-auth"
ENV AWS_API_MCP_TRANSPORT="streamable-http"

CMD ["honcho", "start"]
