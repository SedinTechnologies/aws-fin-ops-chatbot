FROM python:3.13.12-slim

WORKDIR /app

COPY requirements.txt ./

RUN pip install --no-cache-dir -r requirements.txt \
  && rm -rf /var/cache/apt/*

COPY Procfile.mcp ./Procfile

EXPOSE 8001 8002 8003 8004 8005

ENV AWS_REGION="${AWS_REGION:-us-east-1}"
ENV AWS_API_MCP_TRANSPORT="streamable-http"
ENV UVICORN_LOG_LEVEL="debug"

CMD ["honcho", "start"]
