# AI_PROVIDER determines which client backend to use.
# Valid options: AZURE_OPEN_AI or OLLAMA
AI_PROVIDER=AZURE_OPEN_AI

# ----------------------------
# AZURE OPENAI CONFIGURATION
# ----------------------------
OPENAI_API_VERSION=2025-01-01-preview
AZURE_OPENAI_MODEL=gpt-5
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_KEY2=

# ----------------------------
# OLLAMA LOCAL CONFIGURATION
# ----------------------------
# Note: Use http://host.docker.internal:11434 if Ollama runs on your host machine and the app is in Docker
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen3.5:4b
OLLAMA_TEMPERATURE=0.1
OLLAMA_TOP_P=0.9
OLLAMA_TOP_K=40
OLLAMA_NUM_CTX=32768
OLLAMA_NUM_PREDICT=8192
# Repetition penalty prevents the model from looping on the same output.
# Higher values = stronger penalty. Range: 1.0 (off) to 2.0 (aggressive).
OLLAMA_REPEAT_PENALTY=1.3
OLLAMA_REPEAT_LAST_N=256
# Set to true only for thinking-capable models (e.g., deepseek-r1, qwen3-thinking).
# Default false — thinking tokens interfere with tool-call reliability.
OLLAMA_REASONING=false
